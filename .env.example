# Copy this file to .env and fill in real values
# .env is gitignored and should never be committed

# Shared credentials
DB_USER=relay
DB_PASSWORD=changeme

JWT_SECRET=replace-with-a-secure-random-256-bit-secret
JWT_EXPIRATION=86400000

# Auth Service
AUTH_DB_URL=jdbc:postgresql://localhost:5432/auth_db

# User Service
USER_DB_URL=jdbc:postgresql://localhost:5432/user_db
GRPC_PORT=9090

# Message Service
MESSAGE_DB_URL=jdbc:postgresql://localhost:5432/message_db

# RabbitMQ (used by Message Service and Bot Service)
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# BFF — internal service URLs
AUTH_SERVICE_URL=http://localhost:8081
USER_SERVICE_URL=http://localhost:8082
MESSAGE_SERVICE_URL=http://localhost:8083

# Bot Service
BOT_USER_ID=0